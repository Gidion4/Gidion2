// ------------------------------------------------------------
// GIDION LEVEL 4 — AGENT ORCHESTRATOR TEST v1 (ESM-COMPATIBLE)
// ------------------------------------------------------------
// Testaa agentOrchestrator.ts -moduulin keskeiset toiminnot:
//   - agenttien rekisteröinti
//   - tehtävän välitys agentille
//   - tuloksen palautus
//   - deterministinen toiminta
// ------------------------------------------------------------

import { AgentCore } from "./agentCore.js";
import { AgentOrchestrator } from "./agentOrchestrator.js";

function assert(condition: boolean, message: string) {
  if (!condition) {
    console.error("✖ TEST FAILED:", message);
    process.exit(1);
  }
}

async function runTests() {
  console.log("Running AgentOrchestrator tests...");

  const orchestrator = new AgentOrchestrator();

  // --- Test 1: Agentin rekisteröinti ---
  const agent = new AgentCore("TestAgent");
  orchestrator.registerAgent(agent);

  const agents = orchestrator.getAgents();
  assert(agents.length === 1, "Agent was not registered");
  assert(agents[0].name === "TestAgent", "Registered agent name mismatch");

  // --- Test 2: Tehtävän välitys ---
  const result = await orchestrator.dispatchTask("Unit test dispatch", { foo: 42 });

  assert(result.success === true, "Dispatched task did not succeed");
  assert(typeof result.output === "string", "Result output missing");
  assert(
    result.output.includes("completed by TestAgent"),
    "Result output incorrect"
  );

  console.log("✔ All AgentOrchestrator tests passed.");
  process.exit(0);
}

// ------------------------------------------------------------
// CLI ENTRYPOINT (ESM)
// ------------------------------------------------------------

if (import.meta.url === `file://${process.argv[1]}`) {
  runTests();
}
