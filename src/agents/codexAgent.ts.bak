import { AgentRequest, AgentResponse, runAgent } from "./agentBase";

async function codexHandler(req: AgentRequest): Promise<AgentResponse> {
  return {
    ok: true,
    result: `CODEX-agentti käsittelee koodia: ${req.input}`
  };
}

export async function CODEX(req: AgentRequest) {
  return runAgent(codexHandler, req);
}

