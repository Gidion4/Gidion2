// ------------------------------------------------------------
// GIDION LEVEL 3 — ORGANIZATION CONTROLLER v1
// ------------------------------------------------------------
// Tämä kerros yhdistää:
//   - Goal Engine
//   - Task Planner
//   - Autonomy Loop
//
// Se tarjoaa yhden sisääntulopisteen koko Level 3 -järjestelmälle.
// UI, CLI tai API voi kutsua vain tätä.
//
// v1: synkroninen, yksi tavoite kerrallaan
// v2: rinnakkaiset projektit
// v3: jatkuva organisaatiotason autonominen agentti
// ------------------------------------------------------------

import { createGoal, listGoals, getGoal } from "./goalEngine";
import { runAutonomyLoop } from "./autonomyLoop";

export interface OrgCommand {
  type: "create-goal" | "run-goal" | "list-goals" | "status";
  title?: string;
  description?: string;
  goalId?: string;
}

export interface OrgResponse {
  ok: boolean;
  message: string;
  data?: any;
}

// ------------------------------------------------------------
// ORGANIZATION CONTROLLER
// ------------------------------------------------------------

export async function handleOrgCommand(cmd: OrgCommand): Promise<OrgResponse> {
  try {
    // ------------------------------------------------------------
    // LUO TAVOITE
    // ------------------------------------------------------------
    if (cmd.type === "create-goal") {
      if (!cmd.title) {
        return { ok: false, message: "Goal title puuttuu." };
      }

      const goal = createGoal({
        title: cmd.title,
        description: cmd.description
      });

      return {
        ok: true,
        message: "Tavoite luotu.",
        data: goal
      };
    }

    // ------------------------------------------------------------
    // LISTAA TAVOITTEET
    // ------------------------------------------------------------
    if (cmd.type === "list-goals") {
      const goals = listGoals();
      return {
        ok: true,
        message: "Tavoitteet listattu.",
        data: goals
      };
    }

    // ------------------------------------------------------------
    // SUORITA TAVOITE AUTONOMISESTI
    // ------------------------------------------------------------
    if (cmd.type === "run-goal") {
      if (!cmd.goalId) {
        return { ok: false, message: "goalId puuttuu." };
      }

      const goal = getGoal(cmd.goalId);
      if (!goal) {
        return { ok: false, message: "Tavoitetta ei löytynyt." };
      }

      const result = await runAutonomyLoop(goal);

      return {
        ok: result.ok,
        message: result.message,
        data: result
      };
    }

    // ------------------------------------------------------------
    // HAE TAVOITTEEN TILA
    // ------------------------------------------------------------
    if (cmd.type === "status") {
      if (!cmd.goalId) {
        return { ok: false, message: "goalId puuttuu." };
      }

      const goal = getGoal(cmd.goalId);
      if (!goal) {
        return { ok: false, message: "Tavoitetta ei löytynyt." };
      }

      return {
        ok: true,
        message: "Tavoitteen tila haettu.",
        data: goal
      };
    }

    // ------------------------------------------------------------
    // TUNTEMATON KOMENTO
    // ------------------------------------------------------------
    return {
      ok: false,
      message: "Tuntematon Organization-komento."
    };

  } catch (err: any) {
    return {
      ok: false,
      message: "Organization Controller virhe.",
      data: err?.message
    };
  }
}

// ------------------------------------------------------------
// SUORA KÄYTTÖ (CLI)
// ------------------------------------------------------------

if (require.main === module) {
  (async () => {
    const res = await handleOrgCommand({
      type: "create-goal",
      title: "Testaa Organization Controller"
    });

    console.log(JSON.stringify(res, null, 2));
  })();
}
