// ------------------------------------------------------------
// GIDION ULTRAHYBRID LEVEL 4 — SELF HEALING DASHBOARD DATA v1
// ------------------------------------------------------------
// Tämä moduuli yhdistää koko self-healing -ketjun datan
// yhdeksi UI-valmiiksi dashboard-rakenteeksi.
//
// Se EI tee logiikkaa, EI tee korjauksia — vain muotoilee datan.
//
// Dashboard sisältää:
//   - järjestelmän terveystilan yhteenvedon
//   - ongelmalistan
//   - suunnitellut korjaustoimet
//   - dry-run -suoritusraportin
//   - kokonaisarvion
//
// Tämä toimii Gidion UI:n "Self-Healing Dashboard" -paneelin datalähteenä.
// ------------------------------------------------------------

import { runSelfHealingOrchestration } from "./systemSelfHealingOrchestrator.js";

export interface DashboardData {
  timestamp: string;

  systemStatus: {
    healthy: boolean;
    issueCount: number;
    requiresManualReview: boolean;
  };

  issues: {
    key: string;
    description: string;
    severity: string;
  }[];

  plannedActions: {
    issueKey: string;
    severity: string;
    steps: string[];
  }[];

  execution: {
    allSuccessful: boolean;
    actions: {
      issueKey: string;
      severity: string;
      steps: {
        step: string;
        success: boolean;
        message: string;
      }[];
    }[];
  };
}

export async function getSelfHealingDashboardData(): Promise<DashboardData> {
  const orchestration = await runSelfHealingOrchestration();

  return {
    timestamp: orchestration.timestamp,

    systemStatus: {
      healthy: orchestration.coreReport.healthy,
      issueCount: orchestration.coreReport.issues.length,
      requiresManualReview: orchestration.healingPlan.requiresManualReview
    },

    issues: orchestration.coreReport.issues.map(i => ({
      key: i.key,
      description: i.description,
      severity: i.severity
    })),

    plannedActions: orchestration.healingPlan.actions.map(a => ({
      issueKey: a.issueKey,
      severity: a.severity,
      steps: a.steps
    })),

    execution: {
      allSuccessful: orchestration.executionReport.allSuccessful,
      actions: orchestration.executionReport.actions.map(a => ({
        issueKey: a.issueKey,
        severity: a.severity,
        steps: a.results.map(r => ({
          step: r.step,
          success: r.success,
          message: r.message
        }))
      }))
    }
  };
}

// ------------------------------------------------------------
// CLI ENTRYPOINT (ESM)
// ------------------------------------------------------------

if (import.meta.url === `file://${process.argv[1]}`) {
  getSelfHealingDashboardData().then((data) => {
    console.log("Gidion UltraHybrid Level 4 — Self Healing Dashboard Data");
    console.log(JSON.stringify(data, null, 2));
  });
}
